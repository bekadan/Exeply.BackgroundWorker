{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AzureKeyVault": {
    "Uri": "https://exeply-key-vault.vault.azure.net/"
  },
  "AzureServiceBus": {
    "DefaultMaxWaitTime": "00:00:30",
    "DefaultTimeToLive": "01:00:00"
  },
  "ServiceBusWorker": {
    "QueueName": "emails",
    "SubscriptionName": null,
    "MaxConcurrentCalls": 4,
    "RestartDelay": "00:00:10"
  },
  "Email": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "no-reply@exeply.com",
    "FromEmail": "no-reply@exeply.com",
    "FromName": "Exeply",
    "SecureSocketOption": "StartTls",
    "TimeoutSeconds": 30
  }
}
